{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":dependencyDashboard",
    ":enablePreCommit",
    ":preserveSemverRanges",
    ":disableDependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":ignoreModulesAndTests",
    "schedule:weekends",
    "workarounds:all"
  ],
  "assignees": ["dmnktoe"],
  "reviewers": ["dmnktoe"],
  "labels": ["dependencies"],
  "timezone": "Europe/Berlin",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 12,
  "rangeStrategy": "bump",
  "rebaseWhen": "conflicted",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "addLabels": ["priority:high"],
    "assignees": ["dmnktoe"]
  },
  "osvVulnerabilityAlerts": true,
  "configMigration": true,
  "dependencyDashboard": false,
  "packageRules": [
    {
      "description": "Label production dependencies (individual PRs)",
      "matchDepTypes": ["dependencies", "peerDependencies", "optionalDependencies"],
      "addLabels": ["deps:prod"]
    },
    {
      "description": "Group ALL development dependencies into one PR",
      "groupName": "development-dependencies",
      "groupSlug": "dev-deps",
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["deps:dev"]
    },
    {
      "description": "Separate major updates into their own PRs",
      "matchUpdateTypes": ["major"],
      "addLabels": ["breaking", "manual-review"],
      "prPriority": 5
    },
    {
      "description": "Workspace path → app label",
      "matchFileNames": ["apps/portfolio/**"],
      "addLabels": ["app:portfolio"]
    },
    {
      "matchFileNames": ["apps/storybook/**"],
      "addLabels": ["app:storybook"]
    },
    {
      "description": "Workspace path → package label",
      "matchFileNames": ["packages/analytics/**"],
      "addLabels": ["pkg:analytics"]
    },
    {
      "matchFileNames": ["packages/consent/**"],
      "addLabels": ["pkg:consent"]
    },
    {
      "matchFileNames": ["packages/env/**"],
      "addLabels": ["pkg:env"]
    },
    {
      "matchFileNames": ["packages/now-playing/**"],
      "addLabels": ["pkg:now-playing"]
    },
    {
      "matchFileNames": ["packages/observability/**"],
      "addLabels": ["pkg:observability"]
    },
    {
      "matchFileNames": ["packages/storyblok-api/**"],
      "addLabels": ["pkg:storyblok-api"]
    },
    {
      "matchFileNames": ["packages/storyblok-richtext/**"],
      "addLabels": ["pkg:storyblok-richtext"]
    },
    {
      "matchFileNames": ["packages/storyblok-sync/**"],
      "addLabels": ["pkg:storyblok-sync"]
    },
    {
      "matchFileNames": ["packages/storyblok-ui/**"],
      "addLabels": ["pkg:storyblok-ui"]
    },
    {
      "matchFileNames": ["packages/storyblok-utils/**"],
      "addLabels": ["pkg:storyblok-utils"]
    },
    {
      "matchFileNames": ["packages/tokens/**"],
      "addLabels": ["pkg:tokens"]
    },
    {
      "matchFileNames": ["packages/ui/**"],
      "addLabels": ["pkg:ui"]
    },
    {
      "description": "Storyblok umbrella label (workspace + npm)",
      "matchFileNames": [
        "packages/storyblok-api/**",
        "packages/storyblok-richtext/**",
        "packages/storyblok-sync/**",
        "packages/storyblok-ui/**",
        "packages/storyblok-utils/**"
      ],
      "addLabels": ["storyblok"]
    },
    {
      "matchPackageNames": ["storyblok", "storyblok-js-client", "@storyblok/{/,}**"],
      "addLabels": ["storyblok"]
    },
    {
      "description": "Root workspace tooling",
      "matchFileNames": ["package.json"],
      "addLabels": ["scope:root"]
    },
    {
      "description": "GitHub Actions label (no grouping)",
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "description": "Docker label (no grouping)",
      "matchManagers": ["dockerfile", "docker-compose"],
      "addLabels": ["docker"]
    },
    {
      "matchDatasources": ["docker"]
    },
    {
      "description": "Node.js engine bump = manual review",
      "matchDepNames": ["node"],
      "addLabels": ["scope:node", "manual-review"]
    },
    {
      "description": "Flag 0.x bumps as breaking under semver",
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": ["major", "minor"],
      "addLabels": ["manual-review"]
    },
    {
      "description": "pnpm itself: keep packageManager pin fresh",
      "matchDepNames": ["pnpm"],
      "addLabels": ["scope:tooling"]
    }
  ]
}
