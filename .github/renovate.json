{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitTypeAll(chore)",
    ":preserveSemverRanges",
    ":enablePreCommit"
  ],
  "timezone": "Europe/Berlin",
  "assignees": ["dmnktoe"],
  "reviewers": ["dmnktoe"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 12,
  "dependencyDashboard": false,
  "lockFileMaintenance": { "enabled": true },
  "vulnerabilityAlerts": {
    "labels": ["security", "priority:high"],
    "assignees": ["dmnktoe"]
  },
  "packageRules": [
    {
      "description": "Production deps get individual PRs, dev deps are grouped",
      "matchDepTypes": ["dependencies", "peerDependencies", "optionalDependencies"],
      "addLabels": ["deps:prod"]
    },
    {
      "description": "All dev deps land in one PR by default",
      "groupName": "dev-dependencies",
      "matchDepTypes": ["devDependencies"],
      "addLabels": ["deps:dev"]
    },
    {
      "description": "Type definitions get their own group",
      "groupName": "type definitions",
      "matchPackageNames": ["@types/**"],
      "addLabels": ["deps:dev", "deps:types"]
    },
    {
      "description": "Test tooling gets its own group",
      "groupName": "test tooling",
      "matchPackageNames": [
        "vitest",
        "@vitest/**",
        "playwright",
        "@playwright/test",
        "@testing-library/**",
        "jsdom",
        "happy-dom"
      ],
      "addLabels": ["deps:dev", "deps:test"]
    },
    {
      "description": "Storyblok SDK + client move together",
      "groupName": "storyblok",
      "matchPackageNames": ["@storyblok/**", "storyblok-js-client"],
      "addLabels": ["storyblok"]
    },
    {
      "description": "React core moves in lockstep",
      "groupName": "react",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "addLabels": ["react"]
    },
    {
      "description": "Panda CSS toolchain",
      "groupName": "panda css",
      "matchPackageNames": ["@pandacss/**"],
      "addLabels": ["panda"]
    },
    {
      "description": "Lint + format toolchain moves together",
      "groupName": "linting & formatting",
      "matchPackageNames": ["oxlint", "oxfmt"],
      "addLabels": ["deps:dev", "tooling"]
    },
    {
      "description": "Majors and 0.x bumps need a human",
      "matchUpdateTypes": ["major"],
      "addLabels": ["breaking", "manual-review"],
      "prPriority": 5
    },
    {
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": ["major", "minor"],
      "addLabels": ["manual-review"]
    },
    {
      "description": "Workspace scoping",
      "matchFileNames": ["apps/portfolio/**"],
      "addLabels": ["app:portfolio"]
    },
    {
      "matchFileNames": ["apps/storybook/**"],
      "addLabels": ["app:storybook"]
    },
    {
      "matchFileNames": ["packages/**"],
      "addLabels": ["scope:packages"]
    },
    {
      "matchFileNames": ["package.json"],
      "addLabels": ["scope:root"]
    },
    {
      "description": "CI / Docker tooling",
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "addLabels": ["docker"]
    },
    {
      "description": "Toolchain pins need a human (Node engine, pnpm)",
      "matchDepNames": ["node", "pnpm"],
      "addLabels": ["scope:tooling", "manual-review"]
    }
  ]
}
