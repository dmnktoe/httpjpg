# Copy to `.env.local` at the repo root (NOT inside apps/portfolio).
# `packages/env` validates these via Zod at startup; missing required
# values fail fast. NEVER commit `.env.local`.

# -- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -- Storyblok ----------------------------------------------------------------
# Public + Preview tokens: Space Settings → Access Tokens
NEXT_PUBLIC_STORYBLOK_TOKEN=""
NEXT_PUBLIC_STORYBLOK_VERSION="published"
STORYBLOK_PREVIEW_TOKEN=""
# Generate both secrets with `openssl rand -base64 32`
STORYBLOK_PREVIEW_SECRET=""
STORYBLOK_REVALIDATE_SECRET=""
# Management token + space ID — only required when running sync scripts locally.
# Account Settings → Personal Access Tokens.
STORYBLOK_MANAGEMENT_TOKEN=""
STORYBLOK_SPACE_ID=""

# -- Sentry -------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# CI-only: source-map upload. Account → API → Auth Tokens, scope project:releases.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Set to 1 to also report errors during local dev (server + client).
# SENTRY_ENABLE_IN_DEV=1
# NEXT_PUBLIC_SENTRY_ENABLE_IN_DEV=1

# -- Spotify (Now Playing widget) ---------------------------------------------
# Dashboard → Create App. Mint a refresh token via the OAuth helper script.
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REFRESH_TOKEN=""

# -- Discord (presence widget) ------------------------------------------------
# Discord → Enable Developer Mode → right-click your avatar → Copy User ID.
DISCORD_USER_ID=""

# -- Google Analytics ---------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# -- Umami (privacy-first analytics) ------------------------------------------
# Website ID from your Umami dashboard. Leave empty to disable the tracker.
NEXT_PUBLIC_UMAMI_ID=""
# Tracker script URL. Defaults to Umami Cloud; point at your self-hosted instance
# (e.g. https://analytics.example.com/script.js) if you run your own.
# NEXT_PUBLIC_UMAMI_SRC="https://cloud.umami.is/script.js"

# -- Dev ----------------------------------------------------------------------
NODE_ENV=development
# SKIP_ENV_VALIDATION=1
