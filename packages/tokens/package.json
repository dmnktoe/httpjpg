{
  "name": "@httpjpg/tokens",
  "version": "1.1.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./colors": {
      "types": "./src/colors.ts",
      "import": "./src/colors.ts"
    },
    "./typography": {
      "types": "./src/typography.ts",
      "import": "./src/typography.ts"
    },
    "./spacing": {
      "types": "./src/spacing.ts",
      "import": "./src/spacing.ts"
    },
    "./border-radius": {
      "types": "./src/border-radius.ts",
      "import": "./src/border-radius.ts"
    },
    "./shadows": {
      "types": "./src/shadows.ts",
      "import": "./src/shadows.ts"
    },
    "./dist/tokens.css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsx scripts/generate-css-vars.ts",
    "type-check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
