{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "semi": true,
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/styled-system/**",
    "**/styles.css",
    "**/globals.css",
    "**/tailwind-animate.css",
    "**/coverage/**",
    "**/.panda-studio/**",
    "**/storybook-static/**"
  ],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
