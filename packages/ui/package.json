{
  "name": "@httpjpg/ui",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src",
    "styled-system",
    "panda.config.ts",
    "panda.helpers.ts",
    "styles.css"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./styles/global": {
      "types": "./src/styles/global.ts",
      "import": "./src/styles/global.ts"
    },
    "./css": {
      "types": "./styled-system/css/index.d.ts",
      "import": "./styled-system/css/index.mjs"
    },
    "./patterns": {
      "types": "./styled-system/patterns/index.d.ts",
      "import": "./styled-system/patterns/index.mjs"
    },
    "./tokens": {
      "types": "./styled-system/tokens/index.d.ts",
      "import": "./styled-system/tokens/index.mjs"
    },
    "./styled-system/*": "./styled-system/*",
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "prepare": "panda codegen && panda cssgen --outfile styles.css",
    "dev": "panda codegen && panda cssgen --outfile styles.css && concurrently --kill-others --names codegen,cssgen -c blue,green \"panda codegen --watch\" \"panda cssgen --watch --outfile styles.css\"",
    "dev:https": "pnpm run dev",
    "build": "panda codegen && panda cssgen --outfile styles.css",
    "type-check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "clean": "rm -rf styled-system styles.css"
  },
  "dependencies": {
    "@httpjpg/tokens": "workspace:*",
    "framer-motion": "^12.23.24",
    "swiper": "^14.0.0"
  },
  "devDependencies": {
    "@httpjpg/storyblok-utils": "workspace:*",
    "@pandacss/dev": "1.11.3",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "concurrently": "^10.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^18.3.1 || ^19.0.0"
  }
}
